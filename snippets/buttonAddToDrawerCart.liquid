{% if product.variants.size > 1 %}
    <button class="btn btn-primary btn-sm">{{ 'Choose' | t:'collection' }}</button>
{% else %}
    {% form 'cart_update' onSuccess:redirect class:'add-to-cart' %}
        <input type="hidden" name="product" value="{{product.id}}">
        <input type="hidden" name="quantity" value="1">
        <input type="hidden" name="variant" value="{{product.variants[0].id}}">
        <button name="submit" class="btn btn-primary btn-sm{% if product.quantity <= 0 %} btn-disabled" disabled{% else %}"{% endif %}
        {% if settings.mainNavDrawer %}@click.prevent="shop.addToCart('{{product.id}}','{{product.variants[0].id}}',1)"{% endif %}>
            {% unless  product.quantity <= 0 %}
            {{ 'Add to cart' | t }}
            {% else %}
            {{ 'Out of stock' | t }}
            {% endunless %}
       </button>
    {% endform %}
{% endif %}