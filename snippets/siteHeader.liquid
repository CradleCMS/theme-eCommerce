{% comment %}
Responsive header with dropdown menu on small screens and click‑based mega menu on desktop.
{% endcomment %}

{% assign main-nav = settings.main_nav_linklist | def: "main-menu" %}

<div class="bg-{{ settings.header_colors }} text-{{ settings.header_colors }}-content {{ settings.general_shadow }} sticky top-0 w-full z-30">
  <a class="skip-link bg-primary text-primary-content link z-10 w-full p-4 text-center" href="#main-content">
    {{ 'Skip to content' | t:'default' }}
  </a>
  {% if settings.headerTopEnabled %}
    <div class="bg-primary text-primary-content p-2 text-center">
      {% if settings.headerTopURL %}<a href="{{ settings.headerTopURL }}">{% endif %}
        <p class="max-w-8xl mx-auto">{{ settings.headerTopText | t:'default' }}</p>
      {% if settings.headerTopURL %}</a>{% endif %}
    </div>
  {% endif %}

  <div class="navbar max-w-8xl mx-auto container" role="navigation">
    <div class="navbar-start">
      {% if navigation[main-nav].links.size > 0 %}
      <div class="dropdown lg:hidden">
        <div tabindex="0" role="button" class="btn btn-ghost pl-0" aria-label="Menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </div>
        <div tabindex="0" class="menu dropdown-content mt-3 z-[1] p-3 shadow bg-primary text-primary-content rounded-box w-60">
          <div class="overflow-y-auto max-h-[80vh]">
            <ul class="space-y-2">
              {% for link in navigation[main-nav].links %}
                {% if link.type == 'navigation' %}
                  <li class="font-bold">
                    <details>
                      <summary class="uppercase cursor-pointer py-2">{{ link.title }}</summary>
                      <ul class="pl-3 space-y-1">
                        {% for childlink in navigation[link.handle].links %}
                          {% if childlink.type == 'navigation' %}
                            <li>
                              <details>
                                <summary class="cursor-pointer">{{ childlink.title }}</summary>
                                <ul class="pl-4 space-y-1">
                                  {% for subchild in navigation[childlink.handle].links %}
                                    <li><a href="{{ subchild | url }}">{{ subchild.title }}</a></li>
                                  {% endfor %}
                                </ul>
                              </details>
                            </li>
                          {% else %}
                            <li><a href="{{ childlink | url }}">{{ childlink.title }}</a></li>
                          {% endif %}
                        {% endfor %}
                      </ul>
                    </details>
                  </li>
                {% else %}
                  <li class="font-bold"><a href="{{ link | url }}">{{ link.title }}</a></li>
                {% endif %}
              {% endfor %}
            </ul>

            {% if site.langs.size > 1 %}
              <a-lang class="block mt-4">
                <select name="lang" class="select select-primary w-full">
                  {% for l in site.langs | keys | sort %}
                    <option value="{{ l }}" {% if l == lang %}selected{% endif %}>
                      {{ languages[l] | t:'default' }}
                    </option>
                  {% endfor %}
                </select>
              </a-lang>
            {% endif %}

            {% if shop.currencies.size > 1 %}
              <a-currency class="block mt-2">
                <select name="currency" class="select select-primary w-full">
                  {% for c in shop.currencies | keys | sort %}
                    <option value="{{ c }}" {% if c == cart.currency %}selected{% endif %}>{{ c }}</option>
                  {% endfor %}
                </select>
              </a-currency>
            {% endif %}
          </div>
        </div>
      </div>
      {% endif %}

      <a href="/">
        <img src="/logo.png" height="{{ settings.logoHeight | def:40 }}" alt="{{ site.name }}" class="p-2 logo">
      </a>

      <ul class="menu menu-horizontal px-1 hidden lg:flex">
        {% for link in navigation[main-nav].links %}
          {% if link.type == 'navigation' and navigation[link.param].links.size > 0 %}
            <li class="relative font-semibold text-base">

              <details class="group">
                <summary class="cursor-pointer px-3 py-2 hover:bg-primary/20 rounded-lg transition">
                  {{ link.title }}
                </summary>

                <div class="absolute left-0 mt-2 bg-primary/60 backdrop-blur-md text-white border border-white/10 shadow-xl p-6 rounded-xl z-50 min-w-[320px] transition-all duration-200">
                  {% for childlink in navigation[link.param].links %}
                    {% if childlink.type == 'navigation' %}

                      <details class="group">
                        <summary class="font-bold cursor-pointer py-1 px-2 bg-primary/10 rounded-md hover:bg-primary/20 transition flex justify-between items-center">
                          {{ childlink.title }}
                          <span class="opacity-70">›</span>
                        </summary>

                        <div class="absolute left-full top-0 ml-4 bg-primary/60 backdrop-blur-md border border-white/10 shadow-xl p-5 rounded-xl min-w-[240px] transition-all duration-200">
                          <ul class="space-y-2">
                            {% for subchild in navigation[childlink.handle].links %}
                              <li>
                                <a href="{{ subchild | url }}" class="hover:underline block">
                                  {{ subchild.title }}
                                </a>
                              </li>
                            {% endfor %}
                          </ul>
                        </div>
                      </details>
                    {% else %}
                      <a href="{{ childlink | url }}" class="block py-1 px-2 hover:bg-primary/20 rounded-md transition">
                        {{ childlink.title }}
                      </a>
                    {% endif %}
                  {% endfor %}
                </div>
              </details>
            </li>
          {% else %}
            <li class="font-semibold text-base">
              <a href="{{ link | url }}" class="px-3 py-2 hover:bg-primary/20 rounded-lg transition">
                {{ link.title }}
              </a>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>

    <div class="navbar-end gap-2">

      <a-search lang="{{ lang }}" currency="{{ cart.currency }}" class="mr-2 hidden md:inline-block" include="products">
        <label class="input input-ghost px-2 min-w-40">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input class="text-sm min-w-40" type="search" placeholder="{{ 'Search' | t:'search' }}" />
        </label>
      </a-search>

      {% if site.langs.size > 1 %}
        <a-lang class="hidden md:inline-block">
          <select name="lang" class="select bg-transparent w-fit">
            {% for l in site.langs | keys | sort %}
              <option value="{{ l }}" {% if l == lang %}selected{% endif %}>
                {{ languages[l] | t:'default' }}
              </option>
            {% endfor %}
          </select>
        </a-lang>
      {% endif %}

      {% if shop.currencies.size > 1 %}
        <a-currency class="hidden md:inline-block">
          <select name="currency" class="select bg-transparent w-fit">
            {% for c in shop.currencies | keys | sort %}
              <option value="{{ c }}" {% if c == cart.currency %}selected{% endif %}>{{ c }}</option>
            {% endfor %}
          </select>
        </a-currency>
      {% endif %}

      <a class="btn btn-ghost btn-circle btn-sm mr-2" href="/customer/account" aria-label="Account">
        <svg fill="currentColor" width="24" height="24" viewBox="0 0 1024 1024">
          <path d="M858.5 763.6a374 374 0 0 0-80.6-119.5 375.63 375.63 0 0 0-119.5-80.6C719.5 518 760 444.7 760 362c0-137-111-248-248-248S264 225 264 362c0 82.7 40.5 156 102.8 201.1-44.8 18.9-85 46-119.5 80.6a375.63 375.63 0 0 0-80.6 119.5A371.7 371.7 0 0 0 136 901.8a8 8 0 0 0 8 8.2h60c4.4 0 7.9-3.5 8-7.8 2-77.2 33-149.5 87.8-204.3 56.7-56.7 132-87.9 212.2-87.9s155.5 31.2 212.2 87.9C779 752.7 810 825 812 902.2c.1 4.4 3.6 7.8 8 7.8h60a8 8 0 0 0 8-8.2c-1-47.8-10.9-94.3-29.5-138.2zM512 534c-45.9 0-89.1-17.9-121.6-50.4S340 407.9 340 362c0-45.9 17.9-89.1 50.4-121.6S466.1 190 512 190s89.1 17.9 121.6 50.4S684 316.1 684 362c0 45.9-17.9 89.1-50.4 121.6S557.9 534 512 534z"/>
        </svg>
      </a>
      {% include 'cartWidget' %}
    </div>
  </div>

  <div class="p-2 pt-0 md:hidden">
    <div class="max-w-8xl mx-auto container">
      <a-search class="w-full" include="products">
        <label class="input input-sm input-ghost px-2 w-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input class="text-sm" type="search" placeholder="{{ 'Search' | t:'search' }}" />
        </label>
      </a-search>
    </div>
  </div>
</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {

  const desktopMenus = document.querySelectorAll('.navbar-start > ul > li > details');

  desktopMenus.forEach((detail) => {
    detail.addEventListener('toggle', function () {
      if (this.open) {
        desktopMenus.forEach((el) => {
          if (el !== this) el.removeAttribute('open');
        });
      }
    });
  });

  const allMobileDetails = document.querySelectorAll('.dropdown details');
  const mobileMenus = Array.from(allMobileDetails).filter(detail => {
    return !detail.closest('details details'); // ❗ inte nested
  });
  mobileMenus.forEach((detail) => {
    detail.addEventListener('toggle', function () {
      if (this.open) {
        mobileMenus.forEach((el) => {
          if (el !== this) el.removeAttribute('open');
        });
      }
    });
  });

  let resizeTimeout;
  function closeAllMenus() {
    document.querySelectorAll('.navbar details, .dropdown details').forEach((el) => {
      el.removeAttribute('open');
    });
  }
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
      closeAllMenus();
    }, 150);
  });
});
</script>