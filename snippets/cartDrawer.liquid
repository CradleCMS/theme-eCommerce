<div id="drawer-cart" 
     x-data="{ 
        isOpen: false,
        open() {
            this.isOpen = true;
            sessionStorage.setItem('cart_drawer_target', 'open');
            document.body.style.overflow = 'hidden';
        },
        close() {
            this.isOpen = false;
            sessionStorage.removeItem('cart_drawer_target');
            document.body.style.overflow = 'auto';
        },
        init() {
    if (sessionStorage.getItem('cart_drawer_target') === 'open') {
        this.isOpen = true;
        document.body.style.overflow = 'hidden';
        sessionStorage.removeItem('cart_drawer_target');
    }
}
     }" 
     @toggle-cart.window="open()"
     @keydown.escape.window="close()"
     x-show="isOpen"
     x-cloak
     class="relative z-[100]">
    
    <div x-show="isOpen" 
         x-transition:enter="transition opacity-0 ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition opacity-100 ease-in duration-300"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @click="isOpen = false; document.body.style.overflow = 'auto'"
         class="fixed inset-0 bg-black/40 backdrop-blur-sm"></div>

    <div x-show="isOpen"
         x-transition:enter="transition transform ease-out duration-300"
         x-transition:enter-start="translate-x-full"
         x-transition:enter-end="translate-x-0"
         x-transition:leave="transition transform ease-in duration-300"
         x-transition:leave-start="translate-x-0"
         x-transition:leave-end="translate-x-full"
         class="fixed inset-y-0 right-0 w-full max-w-md bg-neutral text-neutral-content shadow-2xl flex flex-col">
        
        <div class="py-4 px-6 border-b border-base-300/50 flex justify-between items-center">
            <h2 class="text-sm font-black uppercase tracking-[0.2em]">{{ 'Cart' | t }}</h2>
            <button @click="isOpen = false; document.body.style.overflow = 'auto'" class="btn btn-ghost btn-sm p-1">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>

        <div class="flex-grow overflow-y-auto px-6">
            {% if cart.items.size > 0 %}
                <div class="space-y-6">
                    {% for item in cart.items %}
                        {% let vt = item.title | split:'|' %}
                        <div class="flex gap-4 mt-6 pb-6 border-b last:border-0 border-base-300/50">
                            <div class="w-20 h-24 bg-gray-50 rounded-lg overflow-hidden flex-shrink-0 border border-base-300/50">
                                <img src="{{ item | product_img_url:200,200 }}" class="w-full h-full object-cover">
                            </div>

                            <div class="flex-grow flex flex-col justify-between">
                                <div>
                                    <div class="flex justify-between items-start gap-2">
                                        <div>
                                            <h3 class="text-[11px] md:text-sm font-black uppercase leading-tight">
                                                {{ vt | first }}
                                            </h3> 
                                            {% if vt.size > 1 %}
                                                <p class="text-[10px] md:text-xs text-neutral-content/50 uppercase font-bold mt-1 tracking-tight">{{ vt | slice:1 | join }}</p>
                                            {% endif %}
                                        </div>
                                        <button type="button" @click.prevent="shop.quantityAdjust('{{item.id}}', 0)" class="btn btn-ghost btn-xs p-1">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2" stroke-linecap="round"/></svg>
                                        </button>
                                    </div>

                                </div>

                                <div class="flex justify-between items-end mt-2">
                                    <div class="flex items-center bg-base-100 text-base-content/60 border rounded-lg overflow-hidden">
                                      <button type="button" 
                                        class="px-2 py-1 text-gray-500 hover:text-black" 
                                        @click="sessionStorage.setItem('cart_drawer_target', 'open'); shop.quantityAdjust('{{item.id}}', parseInt('{{ item.quantity }}') - 1)">
                                         −
                                        </button>
                                        <span class="px-3 py-1 text-[10px] font-bold border-x">{{ item.quantity }}</span>
                                        <button type="button" 
                                        class="px-2 py-1 text-gray-500 hover:text-black" 
                                         @click="sessionStorage.setItem('cart_drawer_target', 'open'); shop.quantityAdjust('{{item.id}}', parseInt('{{ item.quantity }}') + 1)">
                                          +
                                    </button>
                                    </div>
                                    <span class="text-xs font-bold">{{ item.price | money }}</span>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="h-full flex flex-col items-center justify-center pb-20 text-center">
                    <div class="w-16 h-16 bg-gray-50 rounded-full flex items-center justify-center mb-4 text-neutral-content">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" stroke-width="1"/></svg>
                    </div>
                    <p class="text-xs uppercase tracking-widest text-gray-400 italic">{{ 'Your cart is empty' | t}}</p>
                </div>
            {% endif %}
        </div>

        {% if cart.items.size > 0 %}
        <div class="p-6 border-t b-2 bg-neutral/50 border-base-300/50">
            <div class="space-y-2 mb-6">
                <div class="flex justify-between items-center text-xs uppercase font-bold text-neutral-content/50 tracking-widest">
                    <span>{{ 'VAT' | t}}</span>
                    <span>{{ cart.amount.vat | money }}</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-xs font-black uppercase tracking-widest text-neutral-content">Total</span>
                    <span class="text-xl font-black text-neutral-content tracking-tighter">{{ cart.amount.total | money }}</span>
                </div>
            </div>
            <a href="/checkout" class="btn-primary btn flex justify-center items-center text-[11px] font-bold uppercase tracking-[0.2em] transition-all shadow-lg active:scale-[0.98]">
                {{ 'Check out' | t }}
            </a>
        </div>
        {% endif %}
    </div>
</div>

