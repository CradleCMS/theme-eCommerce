<script>
(function() {
  'use strict';

  const form = document.getElementById('product-filters');
  if (!form) return;

  const rangeMin = form.querySelector('.range-min');
  const rangeMax = form.querySelector('.range-max');
  const inputMin = form.querySelector('.input-min');
  const inputMax = form.querySelector('.input-max');
  const priceInputs = form.querySelectorAll('.price-range-input input');
  const rangeInputs = form.querySelectorAll('.range-input input');
  const rangeProgress = form.querySelector('.slider .progress');


  
  const getCheckedValues = (name) => 
    [...form.querySelectorAll(`input[name=${name}]:checked`)]
        .map(i => i.value);

  const isGroupLikeValue = (value) => typeof value === "string" && value.includes("_");
  
  function toggleFilter() {
      const filter = document.querySelector("#filter");
      
      filter.classList.toggle("hidden");
  }
  
  
    function buildParams() {
        const params = new URLSearchParams();

        const seen = new Set();
        const dynamicGroupTags = new Set();

        form.querySelectorAll('input[type="checkbox"]').forEach(input => {
          if (seen.has(input.name)) return;
          seen.add(input.name);
          const values = getCheckedValues(input.name);

          if (!values.length) return;

          // Group filters can have dynamic names (a/b/c etc). 
          // Back-end filtering expects tag values in the "tags" query parameter.
          if (input.name !== "tags" && input.name !== "vendor") {
            values.forEach(value => {
              if (isGroupLikeValue(value)) dynamicGroupTags.add(value);
            });
            return;
          }

          params.set(input.name, values.join(","));
        });

        if (dynamicGroupTags.size) {
          const existingTags = (params.get("tags") || "").split(",").filter(Boolean);
          const mergedTags = [...new Set([...existingTags, ...dynamicGroupTags])];
          params.set("tags", mergedTags.join(","));
        }

        const minValue = inputMin?.value || rangeMin?.value;
        const maxValue = inputMax?.value || rangeMax?.value;

        if (minValue > 0) {
          params.set("price-min", minValue);
        }

        if (maxValue < rangeMax.max) {
          params.set("price-max", maxValue);
        }

        return params;
    }
  
  {%if settings.filter_orientation == "horizontal" %}

    const cache = new Map();
    let currentController;
    let debounceTimer;
    let lastQueryString = "";
    
    const DEBOUNCE_DELAY = 250;
    
    
    
    document.addEventListener("click", (e) => {
        const allDetails = document.querySelectorAll("details[open]");
        
        allDetails.forEach( details => {
            if(!details.contains(e.target)) {
                details.removeAttribute("open")
            }
        })
    })
    
    document.addEventListener("click", (e) => {
        const allDetails = document.querySelectorAll("details[open]");
        
        allDetails.forEach(details => {
            if (!details.contains(e.target)) { 
                details.removeAttribute("open");
            }
        });
    });
 
    
    
    // active filters ------------------
    
    function getReadableValue(value) {
        if(value.includes("_")) {
            return value.split("_").pop();
        } 
        return value;
    }
    
    function getActiveFilterValues() {
        const params = buildParams();
        const activeFilters = [];
        
        for (let [key, value] of params.entries()) {
            if (key === "price-min" || key === "price-max") {
                continue;
            }
            
            const values = value.split(",");
            values.forEach( v => {
                activeFilters.push({
                    rawValue: v,
                    displayValue: getReadableValue(v),
                    paramKey: key,
                    originalValue: v
                });
            });
        }
        
        
        const minValue = params.get("price-min");
        const maxValue = params.get("price-max");
        if (minValue || maxValue) {
            activeFilters.push({
                rawValue: `price-${minValue}-${maxValue}`,
                displayValue: `${minValue ||0} kr - ${maxValue || "{{ selectedPriceMaximum }}"} kr`,
                paramKey: "price",
                isPrice: true,
                minValue: minValue,
                maxValue: maxValue
            });
        }
        
        return activeFilters;
    }
    
    function renderActiveFilters() {
        const container = document.querySelector("#active-filters-list");
        if(!container) return;
        
        const activeFilters = getActiveFilterValues();
        container.innerHTML = '';
        if (activeFilters.length === 0) {
            
            return;
        }
        
        container.innerHTML = activeFilters.map(filter => `
            <li data-param-key="${filter.paramKey}"
                data-original-value="${filter.originalValue || ''}"
                data-is-price="${filter.isPrice || false}"
                data-price-min="${filter.minValue || ''}"
                data-price-max="${filter.maxValue || ''}"
            >
                <span class="filter-label capitalize">${filter.displayValue}</span>
                <button class="remove-filter" aria-label="Ta bort filter">X</button>
            </li>
        `).join('');
        
        if(activeFilters.length !== 0) {
            container.innerHTML += "<a href='{{ request.path }}'>Rensa filter</a>"
        }
    }
    
    function findCheckboxByValue(value) {
        const checkboxes = form.querySelectorAll('input[type="checkbox"]');
        for (let checkbox of checkboxes) {
            if(checkbox.value === value) {
                return checkbox
            }
        }
        return null;
    }
    
    function removeFilter() {
        document.body.addEventListener('click', (e) => {
            const removeBtn = e.target.closest('.remove-filter');
            if (!removeBtn) return;
            
            const li = removeBtn.closest('li')
            const isPrice = li.dataset.isPrice === 'true';
            
            if (isPrice) {
                
                if (inputMin) inputMin.value = '';
                if (inputMax) inputMax.value = '';
                if (rangeMin) rangeMin.value = rangeMin.min;
                if (rangeMax) rangeMax.value = rangeMax.max;
              } else {
                const originalValue = li.dataset.originalValue;
                const checkbox = findCheckboxByValue(originalValue);
                if (checkbox) {
                    checkbox.checked = false;
                }
              }
              
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(performUpdate, DEBOUNCE_DELAY);            
        })
    }
    
    // END active filters ------------------
    
    
    const findGrid = (root) =>
      root.querySelector("#product-grid") ||
      root.querySelector("#product-filter-wrapper > .mt-10.grid") ||
      root.querySelector(".mt-10.grid");

    const updateGrid = (html) => {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, "text/html");

      const newGrid = findGrid(doc);
      const currentGrid = findGrid(document);

      if (newGrid && currentGrid) {
        currentGrid.innerHTML = newGrid.innerHTML;
        return true;
      }

      return false;
    };
    
    function syncUIFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const selectedTags = (params.get("tags") || "").split(",").filter(Boolean);

      form.querySelectorAll("input[type='checkbox']").forEach(input => {
        const valuesForName = (params.get(input.name) || "").split(",").filter(Boolean);

        if (valuesForName.includes(input.value)) {
          input.checked = true;
          return;
        }

        // Also sync dynamic group checkboxes from tags param.
        if (input.name !== "tags" && input.name !== "vendor" && selectedTags.includes(input.value)) {
          input.checked = true;
          return;
        }

        input.checked = false;
      });

      // Price
      const min = params.get("price-min") || "";
      const max = params.get("price-max") || "";
    
      if (inputMin) inputMin.value = min;
      if (inputMax) inputMax.value = max;
      if (rangeMin) rangeMin.value = min || rangeMin.min;
      if (rangeMax) rangeMax.value = max || rangeMax.max;
    
      // Uppdatera slider visuellt
      if (rangeProgress && rangeMin && rangeMax) {
        const minVal = parseInt(rangeMin.value) || 0;
        const maxVal = parseInt(rangeMax.value) || 0;
    
        rangeProgress.style.left = (minVal / rangeMin.max) * 100 + "%";
        rangeProgress.style.right =
          100 - (maxVal / rangeMax.max) * 100 + "%";
      }
    }
    
    async function updateFromUrl(queryString, push = false) {
      const baseUrl = window.location.pathname;
    
      if (queryString === lastQueryString) return;
      lastQueryString = queryString;
    
      const pageUrl = queryString
        ? `${baseUrl}?${queryString}`
        : baseUrl;
    
      const fetchParams = new URLSearchParams(queryString);
      fetchParams.set("section_id", "product-grid");
      const fetchUrl = `${baseUrl}?${fetchParams.toString()}`;
    
      if (cache.has(queryString)) {
        const updated = updateGrid(cache.get(queryString));
        if (!updated) {
          window.location.assign(pageUrl);
          return;
        }
        if (push) history.pushState(null, "", pageUrl);
        return;
      }
    
      if (currentController) currentController.abort();
      currentController = new AbortController();
    
      try {
        const response = await fetch(fetchUrl, {
          signal: currentController.signal
        });
    
        const html = await response.text();
    
        cache.set(queryString, html);
        const updated = updateGrid(html);

        if (!updated) {
          window.location.assign(pageUrl);
          return;
        }
    
        if (push) history.pushState(null, "", pageUrl);
    
      } catch (error) {
        if (error.name !== "AbortError") {
          console.error("Filter fetch failed:", error);
        }
      }
    }
    
    function performUpdate() {
        const params = buildParams();
        const queryString = params.toString().replaceAll("%2C", ",");
        
        updateFromUrl(queryString, true);
        renderActiveFilters();
    }

    form.addEventListener("change", (e) => {
        if (!e.target.matches("input[type='checkbox'], input[type='range'], input[type='number']")) {
            return;
        }
        
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(performUpdate, DEBOUNCE_DELAY);
    });
    
    window.addEventListener("popstate", () => {
      syncUIFromUrl();
      const queryString = window.location.search.slice(1);
      updateFromUrl(queryString, false);
      renderActiveFilters();
    });
    
    syncUIFromUrl();
    renderActiveFilters();
    removeFilter();
    
    document.querySelector("#submit-filter")?.classList.add("hidden");
    
    

{% endif %}

  // Ta bort noJS name-attribut
  document.querySelectorAll('.price-filter--nojs input[name]').forEach(input => {
    input.removeAttribute('name');
  });

  document.documentElement.classList.add('js');

  if (rangeMin) rangeMin.setAttribute('name', 'price-min');
  if (rangeMax) rangeMax.setAttribute('name', 'price-max');

  if (rangeInputs.length === 2 && priceInputs.length === 2 && rangeProgress) {

    const PRICE_GAP = 10;

    const updateProgress = (minVal, maxVal) => {
      rangeProgress.style.left = (minVal / rangeInputs[0].max) * 100 + '%';
      rangeProgress.style.right = 100 - (maxVal / rangeInputs[1].max) * 100 + '%';
    };

    const updateRangeFromInputs = () => {
      const minVal = parseInt(priceInputs[0].value) || parseInt(rangeInputs[0].min);
      const maxVal = parseInt(priceInputs[1].value) || parseInt(rangeInputs[1].max);

      rangeInputs[0].value = minVal;
      rangeInputs[1].value = maxVal;

      updateProgress(minVal, maxVal);
    };

    updateRangeFromInputs();

    priceInputs.forEach((input) => {
      input.addEventListener('input', () => {
        const minPrice = parseInt(priceInputs[0].value) || 0;
        const maxPrice = parseInt(priceInputs[1].value) || 0;

        if (maxPrice - minPrice >= PRICE_GAP && maxPrice <= parseInt(rangeInputs[1].max)) {
          if (input.classList.contains('input-min')) {
            rangeInputs[0].value = minPrice;
          } else {
            rangeInputs[1].value = maxPrice;
          }
          updateProgress(minPrice, maxPrice);
        }
      });
    });

    const handleRangeInput = (e) => {
      const minVal = parseInt(rangeInputs[0].value);
      const maxVal = parseInt(rangeInputs[1].value);

      if (maxVal - minVal < PRICE_GAP) {
        if (e.target.classList.contains('range-min')) {
          rangeInputs[0].value = maxVal - PRICE_GAP;
        } else {
          rangeInputs[1].value = minVal + PRICE_GAP;
        }
        return;
      }

      priceInputs[0].value = minVal;
      priceInputs[1].value = maxVal;

      updateProgress(minVal, maxVal);
    };

    rangeInputs.forEach(input => {
      input.addEventListener('input', handleRangeInput);
    });
  }
})();
</script>