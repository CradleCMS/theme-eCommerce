{% assign maxPrice = collection.productPriceMax %}

{% assign selectedTagsString = "," %}
{% assign selectedVendorsString = "," %}
{% assign selectedPriceMinimum = "" %}
{% assign selectedPriceMaximum = "" %}

{% assign queryParameters = request.query | split: "&" %}
{% for parameter in queryParameters %}
  {% if parameter == "" %}{% continue %}{% endif %}
  {% assign keyValuePair = parameter | split: "=" %}
  {% assign parameterKey = keyValuePair[0] | downcase %}
  {% assign parameterValue = keyValuePair[1] | default: "" %}
  {% assign parameterValue = parameterValue | replace: "%2C", "," | url_decode | strip %}

  {% case parameterKey %}
    {% when "tags" %}
      {% assign tagParts = parameterValue | split: "," %}
      {% for tagPart in tagParts %}
        {% assign cleanedTag = tagPart | strip %}
        {% unless cleanedTag == "" %}
          {% assign wrappedTag = "," | append: cleanedTag | append: "," %}
          {% unless selectedTagsString contains wrappedTag %}
            {% assign selectedTagsString = selectedTagsString | append: cleanedTag | append: "," %}
          {% endunless %}
        {% endunless %}
      {% endfor %}
    {% when "vendor" %}
      {% assign vendorParts = parameterValue | split: "," %}
      {% for vendorPart in vendorParts %}
        {% assign cleanedVendor = vendorPart | strip %}
        {% unless cleanedVendor == "" %}
          {% assign wrapped_vendor = "," | append: cleanedVendor | append: "," %}
          {% unless selectedVendorsString contains wrapped_vendor %}
            {% assign selectedVendorsString = selectedVendorsString | append: cleanedVendor | append: "," %}
          {% endunless %}
        {% endunless %}
      {% endfor %}
    {% when "price-min" %}
      {% assign selectedPriceMinimum = parameterValue %}
    {% when "price-max" %}
      {% assign selectedPriceMaximum = parameterValue %}
  {% endcase %}
{% endfor %}

           <div class="filter-header flex gap-2 items-center">
               <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" width="24" height="24" viewBox="0 0 256 256" xml:space="preserve">
                <g style="stroke: none; stroke-width: 0; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;" transform="translate(1.4065934065934016 1.4065934065934016) scale(2.81 2.81)">
                	<path d="M 87 77.103 H 54.88 c -1.657 0 -3 -1.343 -3 -3 s 1.343 -3 3 -3 H 87 c 1.657 0 3 1.343 3 3 S 88.657 77.103 87 77.103 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                	<path d="M 54.114 18.898 H 3 c -1.657 0 -3 -1.343 -3 -3 s 1.343 -3 3 -3 h 51.114 c 1.657 0 3 1.343 3 3 S 55.771 18.898 54.114 18.898 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                	<path d="M 87 48 H 31.097 c -1.657 0 -3 -1.343 -3 -3 c 0 -1.657 1.343 -3 3 -3 H 87 c 1.657 0 3 1.343 3 3 C 90 46.657 88.657 48 87 48 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                	<path d="M 35.885 77.103 H 3 c -1.657 0 -3 -1.343 -3 -3 s 1.343 -3 3 -3 h 32.885 c 1.657 0 3 1.343 3 3 S 37.542 77.103 35.885 77.103 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                	<path d="M 12.868 48 H 3 c -1.657 0 -3 -1.343 -3 -3 c 0 -1.657 1.343 -3 3 -3 h 9.868 c 1.657 0 3 1.343 3 3 C 15.868 46.657 14.524 48 12.868 48 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                	<path d="M 87 18.898 H 72.521 c -1.657 0 -3 -1.343 -3 -3 s 1.343 -3 3 -3 H 87 c 1.657 0 3 1.343 3 3 S 88.657 18.898 87 18.898 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                	<path d="M 54.114 86.217 H 35.885 c -1.657 0 -3 -1.343 -3 -3 V 64.987 c 0 -1.657 1.343 -3 3 -3 h 18.229 c 1.657 0 3 1.343 3 3 v 18.229 C 57.114 84.874 55.771 86.217 54.114 86.217 z M 38.885 80.217 h 12.229 V 67.987 H 38.885 V 80.217 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                	<path d="M 31.097 57.114 H 12.868 c -1.657 0 -3 -1.343 -3 -3 V 35.885 c 0 -1.657 1.343 -3 3 -3 h 18.229 c 1.657 0 3 1.343 3 3 v 18.229 C 34.097 55.771 32.754 57.114 31.097 57.114 z M 15.868 51.114 h 12.229 V 38.885 H 15.868 V 51.114 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                	<path d="M 72.344 28.013 H 54.114 c -1.657 0 -3 -1.343 -3 -3 V 6.783 c 0 -1.657 1.343 -3 3 -3 h 18.229 c 1.657 0 3 1.343 3 3 v 18.229 C 75.344 26.669 74.001 28.013 72.344 28.013 z M 57.114 22.013 h 12.229 V 9.783 H 57.114 V 22.013 z" style="stroke: none; stroke-width: 1; stroke-dasharray: none; stroke-linecap: butt; stroke-linejoin: miter; stroke-miterlimit: 10; fill: rgb(0,0,0); fill-rule: nonzero; opacity: 1;" transform=" matrix(1 0 0 1 0 0) " stroke-linecap="round"/>
                </g>
                </svg>
               Filter
            </div>
    <form action="{{ collection.url }}" method="get" id="product-filters" class="filters flex {% if settings.filter_orientation == "vertical"%}flex-col {% endif %} flex-wrap" >
    
    {%if settings.show_tags_filter %}
    <div id="tags-wrapper">
        <fieldset class="flex {% if settings.filter_orientation == "vertical"%}flex-col{% else %} flex-wrap {% endif %} mb-2">
            {% assign usedTagsTracker = "," %}
            {% if settings.filter_orientation == "horizontal"%}
            <details class="dropdown" name="filter-dropdown">
              <summary class="btn m-1">
                Tags
                <span class="icon-caret"></span>
              </summary>
              <ul class="menu flex flex-row dropdown-content bg-base-100 rounded-box z-1 w-96 p-2 shadow-md">
            {% endif %}
                {% for tag in collections[collection].productTags %}
                {% unless tag contains "_"%}
                  {% assign normalizedTag = tag | downcase | strip %}
                  {% assign wrappedTag = "," | append: normalizedTag | append: "," %}
        
                  {% unless usedTagsTracker contains wrappedTag %}
                    {% assign searchPattern = "," | append: normalizedTag | append: "," %}
                    <label class="capitalize p-2"> 
                      <input type="checkbox" name="tags" value="{{ normalizedTag }}" {% if selectedTagsString contains searchPattern %}checked{% endif %}>
                      {{ normalizedTag | t:"collection" }}
                    </label>
        
                    {% assign usedTagsTracker = usedTagsTracker | append: normalizedTag | append: "," %}
                  {% endunless %}
                  {% endunless %}
                {% endfor %}
              </ul>
            </details>
        </fieldset>
    </div>
    {% endif %}
    
    {%if settings.show_vendor_filter %}
    <div id="vendor-wrapper">
        {% if settings.filter_orientation == "vertical"%}<div class="filter-header">Vendors</div> {% endif %}
        
        <fieldset class="flex flex-col {% if settings.filter_orientation == "horizontal"%} lg:flex-row {% endif%}  mb-2">
           
           {% if settings.filter_orientation == "horizontal"%}
           <details class="dropdown" name="filter-dropdown">
              <summary class="btn m-1">
                  Vendors
                  <span class="icon-caret"></span>
              </summary>
              <ul class="menu flex flex-row dropdown-content bg-base-100 rounded-box z-1 w-96 p-2 shadow-md">
            {% endif %}
                {% for vendor in collection.productVendors %}
                    {% assign vendorValue = vendor | strip %}
                    {% assign vendorSearchPattern = "," | append: vendorValue | append: "," %}
                    <label class="capitalize p-2" {% if settings.filter_orientation == "horizontal" %} {% endif %}>
                      <input type="checkbox" name="vendor" value="{{ vendorValue | split: " " | join: "+" }}" {% if selectedVendorsString contains vendorSearchPattern %}checked{% endif %}>
                      {{ vendor | t:"collection" }}
                    </label>
                {% endfor %}
              </ul>
            {% endif %}
            </details>
        </fieldset>
    </div>
    
    
    {% if settings.show_group_tags_filter %}
    {% assign groups = '' %}

    {% for tag in collection.productTags %}
      {% if tag contains "_" %}
        {% assign tagParts = tag | split: "_" %}
        {% assign groupName = tagParts.first | downcase %}
        {% assign groups = groups | append: groupName | append: "," %}
      {% endif %}
    {% endfor %}
    
    {% assign groups = groups | split: "," | compact | uniq %}
    
    {% for group in groups %}
    
    <div class="filter-wrapper">
    
    {% if settings.filter_orientation == "vertical" %}    
        <div class="filter-header">{{ group | capitalize }}</div>
    {% endif %}
    
      <fieldset class="flex {% if settings.filter_orientation == "vertical"%}flex-col{% else %} flex-wrap {% endif %} mb-2">
      {% if settings.filter_orientation == "horizontal" %}
      <details class="dropdown" name="filter-dropdown">
        <summary class="btn m-1">
          {{ group | capitalize }}
          <span class="icon-caret"></span>
        </summary>
        <ul class="menu flex flex-row dropdown-content bg-base-100 rounded-box z-1 w-96 p-2 shadow-md">
      {% endif %}
          {% for tag in collection.productTags %}
            {% assign tagLower = tag | downcase %}
            {% assign prefix = group | append: "_" %}
            
            {% if tagLower contains prefix %}

              {% assign tagParts = tag | split: "_" %}
              {% assign option = tagParts.last %}
              {% assign wrappedTagValue = "," | append: tagLower | append: "," %}
              
            <label class="p-2">
              <input type="checkbox" name="tags" value="{{ tagLower }}" {% if selectedTagsString contains wrappedTagValue %}checked{% endif %}>
              {{ option | capitalize }}
            </label>
              
    
            {% endif %}
          {% endfor %}
        </ul>
    
      </details>
      </fieldset>
    </div>

    {% endfor %}
    
    {% endif %}
    
    
    {%if settings.show_price_range_filter %} 
    {%if settings.filter_orientation == "horizontal" %} 
    
    <details class="dropdown" name="filter-dropdown">
        <summary class="btn m-1">
          {{ "price" | capitalize }}
          <span class="icon-caret"></span>
        </summary>
    {% endif %}
            <div id="price-input" class="flex flex-col justify-between">
                <h2>Pris</h2>
                <div class="price-filter mb-2 price-filter--nojs">
                    <label>
                            <input class="nojs-input" placeholder="MIN" type="number" name="price-min" min="0" value="{{ selectedPriceMinimum }}">
                    </label>
                    <span>-</span>
                    <label>
                            <input class="nojs-input" placeholder="MAX" type="number" name="price-max" min="0" value="{{ selectedPriceMaximum }}">
                    </label>
                </div>
                
                
                <div class="price-range-wrapper price-filter--js">
                    
                      <div class="price-range-input">
                        <div class="field">
                          <input id="price-range-minimum" type="number" class="input-min" placeholder="MIN" value="{{ selectedPriceMinimum }}">
                        </div>
                        <span>-</span>
                        <div class="field">
                          <input id="price-range-maximum" type="number" class="input-max" placeholder="MAX" value="{{ selectedPriceMaximum }}">
                        </div>
                      </div>  
                      <div class="slider">
                        <div class="progress"></div> 
                      </div>
                      <div class="range-input">
                        <input type="range" class="range-min" min="0" max="{{ maxPrice | divided_by: 1000 }}" step="1">
                        <input type="range" class="range-max" min="0" max="{{ maxPrice | divided_by: 1000 }}" step="1">
                      </div>
                </div>
                
            </div> 
        </details>
    {% endif %}
        
        {% if settings.filter_orientation == "vertical" %}
        <div id="filter-buttons" class="flex justify-between pb-4">
            <button id="submit-filter" type="submit" class="btn">Filtrera</button>
            <a href="{{ request.path }}" class="btn">{{ 'Rensa filter' | t:'collection' }}</a>
        </div>
        {% endif %}
</form>

{% if settings.filter_orientation == "horizontal"%}
<div id="active-filters">
    <ul id="active-filters-list">
        
    </ul>
</div>
{% endif %}

