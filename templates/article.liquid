{% include 'siteBreadcrumbs' %}

<section class="mx-auto flex flex-col lg:flex-row justify-between" itemscope itemtype="https://schema.org/Article">
    <article class="w-full h-full prose p-4 mx-auto">
        <header>
            <h1 class="mt-2 text-2xl">{{ meta.h1 }}</h1>        
            <p class="text-sm">{{ article.author }}
        		<time itemprop="datePublished" datetime="{{ article.publishAt | date }}"> on {{ article.publishAt | date }}, </time>
        		<time itemprop="dateModified">updated {{ article.updatedAt | date }}</time> 
        	</p>    
        	<div class="divider"></div>
        </header>
        <div class="prose mx-auto {{ article.format }}" itemprop="articleBody">
            {{ article.html }}
        </div>
        <div class="grid grid-cols-2">
            <p><a class="btn btn-ghost" href="{{ article.previous | url }}" {% if article.previous == empty %}disabled{% endif %}>&larr; {{ 'Previous' | t }}</a></p>
        	<p class="text-right"><a class="btn btn-ghost" href="{{ article.next | url }}" {% if article.next == empty %}disabled{% endif %}>{{ 'Next' | t }} &rarr;</a></p>
        </div>
    </article>
    <aside class="bg-base-200 text-base-content lg:ml-4 p-4 max-w-full lg:w-1/4" role="complementary">
	    {% include 'blog-sidebar' %}
    </aside>
</section>
{% if settings.articleRelated %}
<section class="mt-10">
    <header class="flex">
        <h2 class="text-xl mb-4">{{ 'Related articles' | t }}</h2>
    </header>
    {% assign relatedArticles = article | related %}
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
    	{% for article in relatedArticles limit:3 %}
            {% include 'blogCard' %}
    	{% endfor %}
    	</div>
</section>
{% endif %}
