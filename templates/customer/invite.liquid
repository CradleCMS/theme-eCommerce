<section class="p-10 prose mx-auto">
    <div class="card bg-base-100 text-base-content shrink-0 w-full max-w-m {{ settings.general_shadow }}">
    {% unless invite %}
    <div class="card-body text-center">
        <h1>{{ 'Invite not found!' | t }}</h1>
        <p class="text-xl mt-2">{{ 'The invite has probably expired, already been used or deleted.' | t }}</p>
      <div class="text-center mt-4">
        <a class="btn btn-sm btn-ghost" href="{{'customer/login' | url}}">{{ 'Back to login' | t }}</a>
      </div>
    </div>
    {% else %}
        {% form 'customer_invite' class:'customer' id:'customer_invite' onSuccess:'/login' %}
        <h1 class="text-center">{{ 'Account activation' | t }}</h1>
        {% if invite.message != blank %}
        <p class="text-center">{{invite.message}}</p>
        {% endif %}
        <p class="text-sm text-center">{{ 'Set a password to activate your account' | t }}</p>
            
        <div class="card-body text-center">
            {% if request.query contains '.errors' %}
            <div class="alert alert-error">
                <span>{{ 'Sorry, looks like something went wrong, please try again.' | t }}</span>
            </div>
            {% endif %}
            <label class="floating-label">
                <span>{{ 'Password' | t }}</span>
                <input class="input w-full" placeholder="{{ 'Password' | t }}" type="password" name="customer[password]" id="password" autocomplete="new-password" required/>
            </label>
            <label class="floating-label">
                <span>{{ 'Confirm password' | t }}</span>
                <input class="input w-full" placeholder="{{ 'Confirm password' | t }}" type="password" name="customer[password_confirmation]" id="password2" autocomplete="new-password" required/>
            </label>
            <div class="form-control">
                <label class="label">
                    {{'Accept Terms of Service' | t}}
                    <input type="checkbox" class="checkbox" name="customer[accepts]service" required>
                </label>
            </div>
            <div class="form-control">
                <label class="label">
                    {{'Accept news, marketing and product updates' | t}}
                    <input type="checkbox" class="checkbox" name="customer[accepts]marketing">
                </label>
            </div>
            <p class="form-control">
              <button class="btn btn-primary border-none">{{ 'Activate account' | t }}</button>
            </p>
            <input type="hidden" name="invite" value="{{invite.id}}">
            <input type="hidden" name="token" value="{{invite.token}}">
        </div>
        {% endform %}
        <p class="text-center mt-4">
            <small>{{ 'Already have an account with us?' | t }} <a class="" href="{{'customer/login' | url}}">{{ 'Account login' | t }}</a></small>
        </p>
  {% endunless %}    
  </div>
</section>
